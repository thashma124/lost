<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password | Lost & Found Management System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="auth.css">
</head>
<body>

<div class="loader" id="loader">
  <div class="loader-ring"></div>
  <div class="loader-text">LOST<span>&FOUND</span></div>
</div>

<div class="toast-container" id="toastContainer"></div>

<div class="auth-topbar">
  <a href="index.html" class="logo"><i class="fa-solid fa-magnifying-glass-location"></i> LOST<span>&FOUND</span></a>
  <div style="display:flex; align-items:center; gap:16px;">
    <a href="login.html" class="back-home"><i class="fa-solid fa-arrow-left"></i> Back to Login</a>
    <button class="icon-btn" id="themeToggle"><i class="fa-solid fa-moon"></i></button>
  </div>
</div>

<div class="auth-wrapper">
  <div class="auth-visual">
    <i class="fa-solid fa-lock auth-float-icon fi1"></i>
    <i class="fa-solid fa-key auth-float-icon fi2"></i>
    <i class="fa-solid fa-shield-halved auth-float-icon fi3"></i>
    <i class="fa-solid fa-circle-check auth-float-icon fi4"></i>
    <div class="auth-visual-content">
      <img src="https://images.unsplash.com/photo-1633265486064-086b219458ec?w=500&q=80" alt="New password" style="border-radius:20px;">
      <h2>Almost There!</h2>
      <p>Create a new, strong password to keep your Lost & Found account secure going forward.</p>
    </div>
  </div>

  <div class="auth-form-panel">
    <div class="auth-card glass">

      <div id="resetFormWrap">
        <div class="progress-steps">
          <div class="progress-step done"><i class="fa-solid fa-check"></i></div>
          <div class="progress-line done"></div>
          <div class="progress-step done"><i class="fa-solid fa-check"></i></div>
          <div class="progress-line done"></div>
          <div class="progress-step active">3</div>
        </div>

        <div class="auth-header">
          <div class="auth-icon-badge"><i class="fa-solid fa-lock"></i></div>
          <h1>Set New Password</h1>
          <p>Your new password must be different from previous ones</p>
        </div>

        <form id="resetForm">
          <div class="form-group">
            <label>New Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock field-icon"></i>
              <input type="password" id="newPassword" class="password-strength-input" data-meter="resetStrengthMeter" data-label="resetStrengthLabel" placeholder="Enter new password" required>
              <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
            </div>
            <div class="strength-meter" id="resetStrengthMeter"><div></div><div></div><div></div><div></div></div>
            <span class="strength-label" id="resetStrengthLabel">Use 8+ characters with a mix of letters, numbers & symbols</span>
          </div>

          <div class="form-group">
            <label>Confirm New Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock field-icon"></i>
              <input type="password" class="confirm-password-input" data-match="newPassword" placeholder="Re-enter new password" required>
              <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
            </div>
            <div class="field-msg"></div>
          </div>

          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Reset Password</button>
        </form>
      </div>

      <!-- Success -->
      <div id="resetSuccess" style="display:none;">
        <div class="success-state">
          <div class="success-icon"><i class="fa-solid fa-lock-open"></i></div>
          <h2>Password Reset!</h2>
          <p>Your password has been changed successfully. You can now sign in with your new password.</p>
          <a href="login.html"><button class="btn btn-primary"><i class="fa-solid fa-right-to-bracket"></i> Back to Sign In</button></a>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="auth.js"></script>
</body>
</html>
