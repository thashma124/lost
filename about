        <i class="fa-solid fa-arrow-right step-arrow"></i>
      </div>
      <div class="step-card glass reveal">
        <div class="step-num">4</div>
        <i class="fa-solid fa-handshake step-icon"></i>
        <h4>Item Returned</h4>
        <p>Once verified, arrange a secure pickup and the item is marked as returned.</p>
      </div>
    </div>
  </div>
