        <i class="fa-solid fa-arrow-right step-arrow"></i>
      </div>
      <div class="step-card glass reveal">
        <div class="step-num">2</div>
        <i class="fa-solid fa-magnifying-glass step-icon"></i>
        <h4>Smart Matching</h4>
        <p>Our system automatically matches lost reports with found item listings by category.</p>
        <i class="fa-solid fa-arrow-right step-arrow"></i>
      </div>
      <div class="step-card glass reveal">
        <div class="step-num">3</div>
        <i class="fa-solid fa-shield-halved step-icon"></i>
        <h4>Verify Ownership</h4>
