<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create Account | Lost & Found Management System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="auth.css">
</head>
<body>

<div class="loader" id="loader">
  <div class="loader-ring"></div>
  <div class="loader-text">LOST<span>&FOUND</span></div>
</div>

<div class="toast-container" id="toastContainer"></div>

<div class="auth-topbar">
  <a href="index.html" class="logo"><i class="fa-solid fa-magnifying-glass-location"></i> LOST<span>&FOUND</span></a>
  <div style="display:flex; align-items:center; gap:16px;">
    <a href="index.html" class="back-home"><i class="fa-solid fa-arrow-left"></i> Back to Home</a>
    <button class="icon-btn" id="themeToggle"><i class="fa-solid fa-moon"></i></button>
  </div>
</div>

<div class="auth-wrapper">
  <div class="auth-visual">
    <i class="fa-solid fa-id-card auth-float-icon fi1"></i>
    <i class="fa-solid fa-book auth-float-icon fi2"></i>
    <i class="fa-solid fa-headphones auth-float-icon fi3"></i>
    <i class="fa-solid fa-umbrella auth-float-icon fi4"></i>
    <i class="fa-solid fa-clock auth-float-icon fi5"></i>
    <div class="auth-visual-content">
      <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=500&q=80" alt="Join us" style="border-radius:20px;">
      <h2>Join The Community</h2>
      <p>Create your free account to report lost items, list found items, and help reunite belongings with their owners.</p>
      <div class="visual-stats">
        <div class="visual-stat"><h3>1.8K+</h3><span>Reports</span></div>
        <div class="visual-divider"></div>
        <div class="visual-stat"><h3>60s</h3><span>Setup Time</span></div>
        <div class="visual-divider"></div>
        <div class="visual-stat"><h3>100%</h3><span>Free</span></div>
      </div>
    </div>
  </div>

  <div class="auth-form-panel">
    <div class="auth-card glass">
      <div class="auth-header">
        <div class="auth-icon-badge"><i class="fa-solid fa-user-plus"></i></div>
        <h1>Create Account</h1>
        <p>Get started with Lost & Found in seconds</p>
      </div>

      <div class="role-toggle">
        <button type="button" class="active"><i class="fa-solid fa-user-graduate"></i> Student</button>
        <button type="button"><i class="fa-solid fa-chalkboard-user"></i> Staff</button>
      </div>

      <div class="social-auth">
        <button class="social-btn"><i class="fa-brands fa-google"></i> Google</button>
        <button class="social-btn"><i class="fa-brands fa-microsoft"></i> Microsoft</button>
      </div>
      <div class="divider">or register with email</div>

      <form id="registerForm">
        <div class="form-row">
          <div class="form-group">
            <label>Full Name</label>
            <div class="input-wrap">
              <i class="fa-solid fa-user field-icon"></i>
              <input type="text" placeholder="John Doe" required>
            </div>
          </div>
          <div class="form-group">
            <label>Student ID</label>
            <div class="input-wrap">
              <i class="fa-solid fa-id-badge field-icon"></i>
              <input type="text" placeholder="STU-2026-001" required>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label>Email Address</label>
          <div class="input-wrap">
            <i class="fa-solid fa-envelope field-icon"></i>
            <input type="email" placeholder="you@university.edu" required>
          </div>
          <div class="field-msg"></div>
        </div>

        <div class="form-group">
          <label>Phone Number</label>
          <div class="input-wrap">
            <i class="fa-solid fa-phone field-icon"></i>
            <input type="tel" placeholder="+91 98765 43210" required>
          </div>
        </div>

        <div class="form-group">
          <label>Password</label>
          <div class="input-wrap">
            <i class="fa-solid fa-lock field-icon"></i>
            <input type="password" id="regPassword" class="password-strength-input" data-meter="strengthMeter" data-label="strengthLabel" placeholder="Create a password" required>
            <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
          </div>
          <div class="strength-meter" id="strengthMeter"><div></div><div></div><div></div><div></div></div>
          <span class="strength-label" id="strengthLabel">Use 8+ characters with a mix of letters, numbers & symbols</span>
        </div>

        <div class="form-group">
          <label>Confirm Password</label>
          <div class="input-wrap">
            <i class="fa-solid fa-lock field-icon"></i>
            <input type="password" class="confirm-password-input" data-match="regPassword" placeholder="Re-enter your password" required>
            <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
          </div>
          <div class="field-msg"></div>
        </div>

        <div class="form-options">
          <label class="checkbox-wrap">
            <input type="checkbox" id="agreeTerms">
            I agree to the <a href="#" class="forgot-link" style="margin-left:4px;">Terms & Privacy Policy</a>
          </label>
        </div>

        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Create Account</button>
      </form>

      <p class="auth-footer-text">Already have an account? <a href="login.html">Sign in</a></p>
    </div>
  </div>
</div>

<script src="auth.js"></script>
</body>
</html>
