<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password | Lost & Found Management System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="auth.css">
</head>
<body>

<div class="loader" id="loader">
  <div class="loader-ring"></div>
  <div class="loader-text">LOST<span>&FOUND</span></div>
</div>

<div class="toast-container" id="toastContainer"></div>

<div class="auth-topbar">
  <a href="index.html" class="logo"><i class="fa-solid fa-magnifying-glass-location"></i> LOST<span>&FOUND</span></a>
  <div style="display:flex; align-items:center; gap:16px;">
    <a href="login.html" class="back-home"><i class="fa-solid fa-arrow-left"></i> Back to Login</a>
    <button class="icon-btn" id="themeToggle"><i class="fa-solid fa-moon"></i></button>
  </div>
</div>

<div class="auth-wrapper">
  <div class="auth-visual">
    <i class="fa-solid fa-shield-halved auth-float-icon fi1"></i>
    <i class="fa-solid fa-envelope-open-text auth-float-icon fi2"></i>
    <i class="fa-solid fa-lock-open auth-float-icon fi3"></i>
    <i class="fa-solid fa-key auth-float-icon fi4"></i>
    <div class="auth-visual-content">
      <img src="https://images.unsplash.com/photo-1614064548237-096d40aabca8?w=500&q=80" alt="Reset password" style="border-radius:20px;">
      <h2>Forgot Your Password?</h2>
      <p>No worries — it happens. Enter your registered email and we'll send you secure instructions to reset it.</p>
    </div>
  </div>

  <div class="auth-form-panel">
    <div class="auth-card glass">

      <!-- Step 1: Enter email -->
      <div id="forgotStep1">
        <div class="auth-header">
          <div class="auth-icon-badge"><i class="fa-solid fa-key"></i></div>
          <h1>Reset Password</h1>
          <p>Enter the email linked to your account</p>
        </div>

        <form id="forgotForm">
          <div class="form-group">
            <label>Email Address</label>
            <div class="input-wrap">
              <i class="fa-solid fa-envelope field-icon"></i>
              <input type="email" placeholder="you@university.edu" required>
            </div>
            <div class="field-msg"></div>
          </div>

          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Send Reset Link</button>
        </form>

        <p class="auth-footer-text">Remembered your password? <a href="login.html">Back to Sign In</a></p>
      </div>

      <!-- Step 2: Confirmation -->
      <div id="forgotStep2" style="display:none;">
        <div class="success-state">
          <div class="success-icon"><i class="fa-solid fa-envelope-circle-check"></i></div>
          <h2>Check Your Email</h2>
          <p>We've sent password reset instructions to your email address. The link will expire in 15 minutes.</p>
          <a href="verify-otp.html?type=reset"><button class="btn btn-primary"><i class="fa-solid fa-shield-halved"></i> Verify with OTP Instead</button></a>
          <p class="auth-footer-text">Didn't get the email? <a href="#" onclick="showToast('Email resent!','success'); return false;">Resend</a></p>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="auth.js"></script>
</body>
</html>
