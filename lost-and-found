<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FindIt Campus | Lost &amp; Found Management System</title>
<meta name="description" content="A premium campus Lost & Found Management System — report, search and claim items securely.">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<!-- Bootstrap 5 -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css">

<!-- Custom Styles -->
<style>
/* =========================================================
   FindIt Campus — Lost & Found Management System
   Premium Glassmorphism UI
========================================================= */

:root{
  --primary:#2563EB;
  --primary-rgb:37,99,235;
  --secondary:#7C3AED;
  --secondary-rgb:124,58,237;
  --white:#ffffff;
  --light-gray:#F3F5F9;
  --gray-600:#64748B;
  --gray-900:#0F172A;
  --success:#16A34A;
  --danger:#EF4444;
  --warning:#F59E0B;

  --grad-primary:linear-gradient(135deg,var(--primary) 0%,var(--secondary) 100%);
  --grad-soft:linear-gradient(135deg,rgba(37,99,235,.10),rgba(124,58,237,.10));

  --bg:var(--light-gray);
  --surface:rgba(255,255,255,.65);
  --surface-solid:#ffffff;
  --text:var(--gray-900);
  --text-muted:var(--gray-600);
  --border:rgba(15,23,42,.08);
  --glass-border:rgba(255,255,255,.35);
  --shadow-soft:0 10px 30px rgba(15,23,42,.08);
  --shadow-strong:0 20px 45px rgba(37,99,235,.18);
  --radius-lg:24px;
  --radius-md:16px;
  --radius-sm:10px;
  --font-display:'Sora', sans-serif;
  --font-body:'Poppins', sans-serif;
}

[data-theme="dark"]{
  --bg:#0B1120;
  --surface:rgba(21,28,45,.65);
  --surface-solid:#131b2e;
  --text:#E7ECF7;
  --text-muted:#93A0B8;
  --border:rgba(255,255,255,.08);
  --glass-border:rgba(255,255,255,.08);
  --light-gray:#0F1729;
  --shadow-soft:0 10px 30px rgba(0,0,0,.35);
}

*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:var(--font-body);
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
  transition:background .4s ease, color .4s ease;
}
h1,h2,h3,h4,h5,h6{font-family:var(--font-display); font-weight:700; color:var(--text);}
p{color:var(--text-muted);}
a{text-decoration:none;}
.text-grad{
  background:var(--grad-primary);
  -webkit-background-clip:text;
  background-clip:text;
  color:transparent;
}
::selection{background:var(--primary); color:#fff;}

/* =========== Scrollbar =========== */
::-webkit-scrollbar{width:9px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--grad-primary); border-radius:10px;}

/* =========== Preloader =========== */
#preloader{
  position:fixed; inset:0; z-index:9999;
  background:var(--grad-primary);
  display:flex; align-items:center; justify-content:center;
  transition:opacity .6s ease, visibility .6s ease;
}
#preloader.hide{opacity:0; visibility:hidden;}
.preloader-inner{text-align:center; color:#fff;}
.preloader-ring{
  width:80px;height:80px;border-radius:50%;
  border:4px solid rgba(255,255,255,.25);
  border-top-color:#fff;
  animation:spin 1s linear infinite;
  margin:0 auto 18px;
  position:relative;
}
.preloader-icon{
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  font-size:1.6rem;
}
.preloader-inner p{color:rgba(255,255,255,.85); font-weight:500; letter-spacing:.5px; margin-top:10px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* =========== Scroll progress =========== */
.scroll-progress{position:fixed; top:0; left:0; width:100%; height:3px; z-index:1051; background:transparent;}
.scroll-progress-bar{height:100%; width:0%; background:var(--grad-primary); transition:width .1s ease;}

/* =========== Glass Nav =========== */
.glass-nav{
  background:var(--surface);
  backdrop-filter:blur(18px) saturate(160%);
  -webkit-backdrop-filter:blur(18px) saturate(160%);
  border-bottom:1px solid var(--glass-border);
  padding:14px 0;
  transition:all .35s ease;
}
.glass-nav.scrolled{
  padding:8px 0;
  box-shadow:var(--shadow-soft);
}
.brand{
  font-family:var(--font-display);
  font-weight:800;
  font-size:1.35rem;
  color:var(--text);
  display:flex; align-items:center; gap:10px;
}
.brand-icon{
  width:40px;height:40px;border-radius:12px;
  background:var(--grad-primary);
  color:#fff; display:flex; align-items:center; justify-content:center;
  box-shadow:var(--shadow-strong);
  font-size:1.1rem;
}
.nav-link{
  font-weight:500; color:var(--text) !important;
  padding:10px 16px !important; border-radius:30px;
  transition:all .3s ease; position:relative;
}
.nav-ic{margin-right:7px; font-size:.85rem; color:var(--primary);}
.nav-link:hover, .nav-link.active{
  background:var(--grad-soft);
  color:var(--primary) !important;
}
.nav-actions{margin-left:12px;}
.icon-btn{
  width:42px;height:42px;border-radius:50%;
  border:1px solid var(--border);
  background:var(--surface-solid);
  color:var(--text);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; position:relative; transition:all .3s ease;
}
.icon-btn:hover{transform:translateY(-3px); box-shadow:var(--shadow-soft); color:var(--primary);}
.notif-dot{
  position:absolute; top:8px; right:9px; width:8px;height:8px;border-radius:50%;
  background:var(--secondary); box-shadow:0 0 0 2px var(--surface-solid);
}
.btn-sm-nav{padding:10px 22px !important; border-radius:30px !important;}

/* =========== Buttons =========== */
.btn-grad{
  background:var(--grad-primary);
  color:#fff !important;
  border:none;
  border-radius:14px;
  padding:12px 26px;
  font-weight:600;
  box-shadow:0 10px 25px rgba(var(--primary-rgb),.35);
  transition:all .35s cubic-bezier(.2,.8,.2,1);
  position:relative;
  overflow:hidden;
}
.btn-grad::before{
  content:'';
  position:absolute; inset:0;
  background:linear-gradient(135deg,var(--secondary),var(--primary));
  opacity:0; transition:opacity .35s ease;
}
.btn-grad span, .btn-grad i{position:relative; z-index:1;}
.btn-grad:hover{
  transform:translateY(-3px) scale(1.02);
  box-shadow:0 16px 35px rgba(var(--secondary-rgb),.4);
  color:#fff;
}
.btn-grad:hover::before{opacity:1;}
.btn-outline-grad{
  background:transparent;
  border:2px solid var(--primary);
  color:var(--primary) !important;
  border-radius:14px;
  padding:10px 24px;
  font-weight:600;
  transition:all .3s ease;
}
.btn-outline-grad:hover{
  background:var(--grad-primary);
  color:#fff !important;
  border-color:transparent;
  transform:translateY(-3px);
  box-shadow:0 12px 25px rgba(var(--primary-rgb),.3);
}
.pulse-btn{animation:pulseGlow 2.6s infinite;}
@keyframes pulseGlow{
  0%,100%{box-shadow:0 10px 25px rgba(var(--primary-rgb),.35);}
  50%{box-shadow:0 10px 40px rgba(var(--secondary-rgb),.55);}
}

/* =========== Glass surfaces =========== */
.glass-card, .glass-panel{
  background:var(--surface);
  backdrop-filter:blur(20px) saturate(160%);
  -webkit-backdrop-filter:blur(20px) saturate(160%);
  border:1px solid var(--glass-border);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-soft);
}
.glass-panel{padding:36px;}
@media(max-width:576px){.glass-panel{padding:22px;}}

/* =========== Hero =========== */
.hero{
  position:relative;
  padding:170px 0 110px;
  overflow:hidden;
  background:
    radial-gradient(circle at 15% 20%, rgba(var(--primary-rgb),.10), transparent 45%),
    radial-gradient(circle at 85% 80%, rgba(var(--secondary-rgb),.12), transparent 45%),
    var(--bg);
}
.hero-blob{position:absolute; border-radius:50%; filter:blur(70px); opacity:.55; z-index:0;}
.blob-1{width:420px;height:420px; background:rgba(var(--primary-rgb),.25); top:-120px; left:-140px; animation:floatSlow 10s ease-in-out infinite;}
.blob-2{width:380px;height:380px; background:rgba(var(--secondary-rgb),.25); bottom:-140px; right:-120px; animation:floatSlow 12s ease-in-out infinite reverse;}
@keyframes floatSlow{0%,100%{transform:translateY(0) translateX(0);}50%{transform:translateY(-30px) translateX(20px);}}

.badge-pill{
  display:inline-flex; align-items:center; gap:8px;
  background:var(--grad-soft);
  color:var(--primary);
  padding:8px 18px; border-radius:30px;
  font-size:.85rem; font-weight:600;
  border:1px solid rgba(var(--primary-rgb),.2);
}
.hero-title{
  font-size:3.2rem; line-height:1.15; font-weight:800; margin:22px 0 18px;
}
.hero-sub{font-size:1.15rem; max-width:520px; margin-bottom:8px;}
.hero-trust{display:flex; gap:36px; flex-wrap:wrap;}
.hero-trust div{display:flex; flex-direction:column;}
.hero-trust strong{font-family:var(--font-display); font-size:1.5rem; color:var(--text);}
.hero-trust span{font-size:.82rem; color:var(--text-muted);}

.hero-art{position:relative; height:460px; z-index:1;}
.hero-illustration{
  width:100%; height:100%;
  border-radius:32px;
  background:var(--grad-primary);
  display:flex; align-items:center; justify-content:center;
  box-shadow:var(--shadow-strong);
  position:relative; overflow:hidden;
}
.hero-illustration::before{
  content:''; position:absolute; inset:0;
  background:radial-gradient(circle at 30% 30%, rgba(255,255,255,.35), transparent 55%);
}
.hero-illustration i{font-size:9rem; color:rgba(255,255,255,.92); filter:drop-shadow(0 15px 25px rgba(0,0,0,.2));}
.hero-card{
  position:absolute; padding:16px 20px; display:flex; align-items:center; gap:14px;
  z-index:2; min-width:230px;
}
.hero-card i{font-size:1.6rem; color:var(--primary);}
.hero-card div{display:flex; flex-direction:column;}
.hero-card strong{font-size:.92rem; color:var(--text);}
.hero-card span{font-size:.75rem; color:var(--text-muted);}
.card-float-1{top:6%; left:-6%; animation:floatY 4.5s ease-in-out infinite;}
.card-float-2{bottom:8%; right:-6%; animation:floatY 5.2s ease-in-out infinite .5s;}
@keyframes floatY{0%,100%{transform:translateY(0);}50%{transform:translateY(-16px);}}

.floating-icon{
  position:absolute; color:rgba(var(--primary-rgb),.18); font-size:2.2rem; z-index:0;
  animation:floatY 6s ease-in-out infinite;
}
.fi-1{top:18%; left:6%; animation-duration:7s;}
.fi-2{top:60%; left:12%; animation-duration:5.5s; color:rgba(var(--secondary-rgb),.18);}
.fi-3{top:22%; right:8%; animation-duration:6.5s;}
.fi-4{bottom:14%; right:20%; animation-duration:8s; color:rgba(var(--secondary-rgb),.18);}
.fi-5{bottom:30%; left:35%; animation-duration:9s;}

.scroll-down-cue{
  position:absolute; bottom:26px; left:50%; transform:translateX(-50%);
  width:38px;height:38px;border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  border:1px solid var(--border); color:var(--primary);
  animation:bounce 2s infinite;
}
@keyframes bounce{0%,100%{transform:translate(-50%,0);}50%{transform:translate(-50%,8px);}}

/* =========== Sections generic =========== */
.section{padding:90px 0;}
.alt-bg{background:var(--surface);}
.section-head{text-align:center; max-width:640px; margin:0 auto 48px;}
.eyebrow{
  display:inline-block; color:var(--secondary); font-weight:700; font-size:.8rem;
  letter-spacing:2px; text-transform:uppercase; margin-bottom:10px;
}
.section-title{font-size:2.2rem; margin-bottom:12px;}
.section-title-sm{font-size:1.3rem;}
.section-desc{margin:0;}

/* =========== Stats =========== */
.stats-section{padding-top:0;}
.stat-card{
  background:var(--surface-solid);
  border:1px solid var(--border);
  border-radius:var(--radius-md);
  padding:28px 20px;
  text-align:center;
  box-shadow:var(--shadow-soft);
  transition:all .35s ease;
}
.stat-card:hover{transform:translateY(-8px); box-shadow:var(--shadow-strong);}
.stat-icon{
  width:58px;height:58px;border-radius:16px;
  display:flex; align-items:center; justify-content:center;
  margin:0 auto 14px; font-size:1.4rem; color:#fff;
}
.icon-blue{background:linear-gradient(135deg,#2563EB,#3B82F6);}
.icon-purple{background:linear-gradient(135deg,#7C3AED,#A855F7);}
.icon-green{background:linear-gradient(135deg,#16A34A,#22C55E);}
.icon-orange{background:linear-gradient(135deg,#F59E0B,#FB923C);}
.stat-card h3{font-size:2.1rem; margin-bottom:4px;}
.stat-card p{margin:0; font-weight:500; font-size:.9rem;}

/* =========== Search Panel =========== */
.search-section{padding-top:60px;}
.search-panel{padding:32px;}
.input-icon-group{position:relative;}
.input-icon-group i{position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--text-muted);}
.input-icon-group input{padding-left:42px !important;}
.input-icon-group.compact{min-width:220px;}
.form-label{font-weight:600; font-size:.85rem; color:var(--text); margin-bottom:6px;}
.form-control, .form-select{
  border-radius:12px; border:1px solid var(--border);
  padding:12px 14px; background:var(--surface-solid); color:var(--text);
  font-size:.92rem;
}
.form-control:focus, .form-select:focus{
  border-color:var(--primary);
  box-shadow:0 0 0 4px rgba(var(--primary-rgb),.12);
  background:var(--surface-solid); color:var(--text);
}

/* =========== Categories =========== */
.category-card{
  background:var(--surface-solid);
  border:1px solid var(--border);
  border-radius:var(--radius-md);
  padding:30px 16px;
  text-align:center;
  cursor:pointer;
  transition:all .35s ease;
  height:100%;
}
.category-card i{
  font-size:1.9rem; margin-bottom:14px; display:block;
  background:var(--grad-primary); -webkit-background-clip:text; background-clip:text; color:transparent;
  transition:transform .35s ease;
}
.category-card span{display:block; font-weight:600; color:var(--text);}
.category-card small{color:var(--text-muted); font-size:.78rem;}
.category-card:hover{
  transform:translateY(-8px);
  box-shadow:var(--shadow-strong);
  border-color:transparent;
  background:var(--grad-primary);
}
.category-card:hover i{-webkit-text-fill-color:#fff; color:#fff; transform:scale(1.15) rotate(-6deg);}
.category-card:hover span, .category-card:hover small{color:#fff;}

/* =========== Item cards =========== */
.item-card{
  background:var(--surface-solid);
  border:1px solid var(--border);
  border-radius:var(--radius-md);
  overflow:hidden;
  height:100%;
  transition:all .35s ease;
  box-shadow:var(--shadow-soft);
}
.item-card:hover{transform:translateY(-8px); box-shadow:var(--shadow-strong);}
.item-img-wrap{position:relative; height:190px; overflow:hidden;}
.item-img-wrap img{width:100%; height:100%; object-fit:cover; transition:transform .5s ease;}
.item-card:hover .item-img-wrap img{transform:scale(1.08);}
.status-badge{
  position:absolute; top:12px; right:12px;
  padding:5px 14px; border-radius:30px; font-size:.72rem; font-weight:700;
  text-transform:uppercase; letter-spacing:.5px; color:#fff;
  backdrop-filter:blur(6px);
}
.badge-lost{background:rgba(239,68,68,.9);}
.badge-found{background:rgba(37,99,235,.9);}
.badge-returned{background:rgba(22,163,74,.9);}
.badge-pending{background:rgba(245,158,11,.92);}
.item-body{padding:18px 20px;}
.item-body h5{font-size:1.05rem; margin-bottom:6px;}
.item-body p{font-size:.85rem; margin-bottom:12px;}
.item-meta{display:flex; flex-direction:column; gap:6px; font-size:.8rem; color:var(--text-muted); margin-bottom:14px;}
.item-meta span i{color:var(--primary); width:16px; margin-right:6px;}
.item-cat-tag{
  display:inline-block; font-size:.7rem; font-weight:600; color:var(--secondary);
  background:rgba(var(--secondary-rgb),.1); padding:4px 10px; border-radius:20px; margin-bottom:10px;
}

/* =========== Pagination =========== */
.custom-pagination .page-link{
  border:none; border-radius:10px !important; margin:0 4px;
  color:var(--text); background:var(--surface-solid); font-weight:600;
  border:1px solid var(--border);
}
.custom-pagination .page-item.active .page-link{background:var(--grad-primary); color:#fff; border-color:transparent;}

/* =========== Forms Section =========== */
.tip-list{list-style:none; padding:0; margin-top:22px;}
.tip-list li{margin-bottom:12px; color:var(--text-muted); font-size:.92rem;}
.tip-list i{color:var(--success); margin-right:10px;}
.form-panel textarea{resize:vertical;}
.upload-box{
  border:2px dashed rgba(var(--primary-rgb),.35);
  border-radius:var(--radius-md);
  padding:30px; text-align:center; cursor:pointer;
  transition:all .3s ease;
  background:var(--grad-soft);
}
.upload-box.compact{padding:16px;}
.upload-box:hover, .upload-box.dragover{border-color:var(--primary); background:rgba(var(--primary-rgb),.08);}
.upload-box i{font-size:1.8rem; color:var(--primary); margin-bottom:8px; display:block;}
.upload-box p{margin:0; font-size:.85rem;}
.upload-box span{color:var(--primary); font-weight:600; text-decoration:underline;}
.image-preview{display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;}
.image-preview img{width:88px;height:88px;object-fit:cover;border-radius:12px; border:1px solid var(--border);}
.form-control.is-invalid, .form-select.is-invalid{border-color:var(--danger);}
.form-control.is-valid, .form-select.is-valid{border-color:var(--success);}

/* =========== Claim Section =========== */
.claim-card{
  background:var(--surface-solid); border:1px solid var(--border);
  border-radius:var(--radius-md); padding:26px 22px; height:100%;
  transition:all .3s ease;
}
.claim-card:hover{transform:translateY(-6px); box-shadow:var(--shadow-soft);}
.claim-card i{font-size:1.8rem; color:var(--primary); margin-bottom:12px; display:block;}
.claim-card h5{font-size:1.02rem; margin-bottom:8px;}
.claim-card p{font-size:.83rem; margin-bottom:14px;}
.otp-inputs{display:flex; gap:10px;}
.otp-box{
  width:100%; text-align:center; font-size:1.2rem; font-weight:700;
  border-radius:10px; border:1px solid var(--border); padding:10px 0;
  background:var(--surface-solid); color:var(--text);
}
.otp-box:focus{outline:none; border-color:var(--primary); box-shadow:0 0 0 3px rgba(var(--primary-rgb),.15);}
.qr-box{
  width:110px;height:110px; margin:0 auto; border-radius:14px;
  background:var(--grad-soft); display:flex; align-items:center; justify-content:center;
  font-size:3rem; color:var(--primary); border:1px dashed rgba(var(--primary-rgb),.4);
}
.claim-status-panel{padding:36px 28px;}
.claim-tracker{display:flex; justify-content:space-between; position:relative; flex-wrap:wrap; gap:20px;}
.claim-tracker::before{
  content:''; position:absolute; top:22px; left:5%; right:5%; height:3px; background:var(--border); z-index:0;
}
.track-step{flex:1; min-width:110px; text-align:center; position:relative; z-index:1;}
.track-dot{
  width:46px;height:46px;border-radius:50%; display:flex; align-items:center; justify-content:center;
  background:var(--surface-solid); border:2px solid var(--border); margin:0 auto 10px; color:var(--text-muted);
  transition:all .3s ease;
}
.track-step.done .track-dot{background:var(--success); border-color:var(--success); color:#fff;}
.track-step.active .track-dot{background:var(--grad-primary); border-color:transparent; color:#fff; box-shadow:0 0 0 6px rgba(var(--primary-rgb),.15);}
.track-step p{font-size:.8rem; font-weight:600; color:var(--text); margin:0;}

/* =========== Admin =========== */
.col-lg-2-4{width:20%;}
@media(max-width:991px){.col-lg-2-4{width:auto;}}
.admin-mini-card{
  background:var(--surface-solid); border:1px solid var(--border); border-radius:var(--radius-md);
  padding:22px; text-align:center; transition:all .3s ease;
}
.admin-mini-card:hover{transform:translateY(-6px); box-shadow:var(--shadow-soft);}
.admin-mini-card i{font-size:1.5rem; color:var(--primary); margin-bottom:10px; display:block;}
.admin-mini-card h4{font-size:1.5rem; margin-bottom:2px;}
.admin-mini-card span{font-size:.78rem; color:var(--text-muted); font-weight:500;}
.admin-table-panel{padding:28px;}
.admin-table{margin-bottom:0;}
.admin-table thead th{
  border-bottom:2px solid var(--border); font-size:.75rem; text-transform:uppercase;
  letter-spacing:.6px; color:var(--text-muted); font-weight:700;
}
.admin-table td{border-color:var(--border); font-size:.88rem; color:var(--text); vertical-align:middle;}
.admin-table tr{transition:background .2s ease;}
.admin-table tbody tr:hover{background:rgba(var(--primary-rgb),.05);}
.pill-status{padding:5px 12px; border-radius:20px; font-size:.72rem; font-weight:700;}
.pill-approved{background:rgba(22,163,74,.12); color:var(--success);}
.pill-rejected{background:rgba(239,68,68,.12); color:var(--danger);}
.pill-pending{background:rgba(245,158,11,.15); color:var(--warning);}

/* =========== Notifications Offcanvas =========== */
.offcanvas{background:var(--surface); backdrop-filter:blur(20px); border:none;}
.notif-item{
  display:flex; gap:14px; padding:16px 0; border-bottom:1px solid var(--border);
}
.notif-item i{font-size:1.3rem; margin-top:3px;}
.notif-item strong{display:block; font-size:.9rem; color:var(--text);}
.notif-item p{margin:2px 0; font-size:.82rem;}
.notif-item small{color:var(--text-muted); font-size:.72rem;}
.text-purple{color:var(--secondary) !important;}

/* =========== Footer =========== */
.footer{
  background:var(--gray-900);
  color:#CBD5E1;
  padding:70px 0 24px;
  margin-top:40px;
}
[data-theme="dark"] .footer{background:#060a14;}
.footer h6{color:#fff; font-weight:700; margin-bottom:16px; font-size:.95rem;}
.footer ul{list-style:none; padding:0; margin:0;}
.footer ul li{margin-bottom:10px;}
.footer ul li a{color:#94A3B8; font-size:.88rem; transition:all .25s ease;}
.footer ul li a:hover{color:#fff; padding-left:4px;}
.footer-about{color:#94A3B8; font-size:.88rem; margin:14px 0 18px; max-width:320px;}
.social-icons{display:flex; gap:10px;}
.social-icons a{
  width:38px;height:38px;border-radius:50%; background:rgba(255,255,255,.06);
  display:flex; align-items:center; justify-content:center; color:#fff;
  transition:all .3s ease;
}
.social-icons a:hover{background:var(--grad-primary); transform:translateY(-4px);}
.footer hr{border-color:rgba(255,255,255,.1); margin:36px 0 18px;}
.footer-bottom{font-size:.8rem; color:#94A3B8;}

/* =========== Scroll to top =========== */
#scrollTopBtn{
  position:fixed; bottom:26px; right:26px; z-index:1000;
  width:50px;height:50px;border-radius:50%; border:none;
  background:var(--grad-primary); color:#fff; font-size:1.1rem;
  box-shadow:var(--shadow-strong);
  opacity:0; visibility:hidden; transform:translateY(20px);
  transition:all .35s ease;
}
#scrollTopBtn.show{opacity:1; visibility:visible; transform:translateY(0);}
#scrollTopBtn:hover{transform:translateY(-5px) scale(1.05);}

/* =========== Toasts =========== */
.custom-toast{
  min-width:300px; border-radius:14px; border:1px solid var(--border);
  background:var(--surface-solid); box-shadow:var(--shadow-strong);
  padding:14px 16px; display:flex; gap:12px; align-items:flex-start; margin-bottom:10px;
  animation:slideInToast .4s ease;
}
@keyframes slideInToast{from{transform:translateX(50px); opacity:0;} to{transform:translateX(0); opacity:1;}}
.custom-toast i{font-size:1.2rem; margin-top:2px;}
.custom-toast strong{display:block; font-size:.88rem; color:var(--text);}
.custom-toast p{margin:2px 0 0; font-size:.8rem; color:var(--text-muted);}

/* =========== Empty state =========== */
.empty-state{
  text-align:center; padding:60px 20px; width:100%;
}
.empty-state i{font-size:3.4rem; color:rgba(var(--primary-rgb),.35); margin-bottom:18px; display:block;}
.empty-state h5{margin-bottom:8px;}
.empty-state p{max-width:360px; margin:0 auto;}

/* =========== Animations =========== */
.fade-up{opacity:0; transform:translateY(36px); transition:all .7s cubic-bezier(.2,.8,.2,1);}
.fade-up.in-view{opacity:1; transform:translateY(0);}
.delay-1.in-view{transition-delay:.1s;}
.delay-2.in-view{transition-delay:.2s;}
.delay-3.in-view{transition-delay:.3s;}

/* =========== Dark mode icon swap =========== */
[data-theme="dark"] #themeToggle i::before{content:"\f185";}

/* =========== Responsive =========== */
@media(max-width:991px){
  .hero{padding:150px 0 80px;}
  .hero-title{font-size:2.4rem;}
  .hero-art{height:360px; margin-top:20px;}
  .navbar-collapse{
    background:var(--surface-solid); border-radius:18px; padding:18px;
    box-shadow:var(--shadow-soft); margin-top:10px; border:1px solid var(--border);
  }
  .nav-actions{margin-left:0; margin-top:14px;}
}
@media(max-width:576px){
  .section{padding:60px 0;}
  .section-title{font-size:1.7rem;}
  .hero-title{font-size:2rem;}
  .hero-illustration i{font-size:6rem;}
  .claim-tracker{flex-direction:column; align-items:flex-start;}
  .claim-tracker::before{display:none;}
  .track-step{display:flex; align-items:center; gap:14px; text-align:left; min-width:0;}
  .track-dot{margin:0;}
}

</style>
