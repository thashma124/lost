<!-- Bootstrap Bundle JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
<script>
/* =========================================================
   FindIt Campus — Lost & Found Management System
   Main JavaScript
========================================================= */

document.addEventListener('DOMContentLoaded', () => {

  /* ---------- Preloader ---------- */
  const preloader = document.getElementById('preloader');
  window.addEventListener('load', () => {
    setTimeout(() => preloader.classList.add('hide'), 500);
  });
  // Fallback in case load already fired
  setTimeout(() => preloader && preloader.classList.add('hide'), 2000);

  /* ---------- Sample Data ---------- */
  const PLACEHOLDER = (seed, w = 400, h = 300) => `https://placehold.co/${w}x${h}/2563EB/ffffff?text=${encodeURIComponent(seed)}`;

  const lostItems = [
    { id:'LF-1001', name:'Black Leather Wallet', desc:'Bifold wallet with college ID inside.', category:'Wallets', location:'Cafeteria', date:'2026-07-14', status:'Lost', img:PLACEHOLDER('Wallet') },
    { id:'LF-1002', name:'iPhone 13 Pro', desc:'Graphite color, cracked top-right corner.', category:'Mobile Phones', location:'Library', date:'2026-07-15', status:'Lost', img:PLACEHOLDER('iPhone') },
    { id:'LF-1003', name:'Dorm Room Keys', desc:'Set of 3 keys on a red keychain.', category:'Keys', location:'Hostel Block C', date:'2026-07-12', status:'Pending', img:PLACEHOLDER('Keys') },
    { id:'LF-1004', name:'Data Structures Textbook', desc:'CLRS 3rd edition, name written inside cover.', category:'Books', location:'Main Block, Room 204', date:'2026-07-10', status:'Lost', img:PLACEHOLDER('Book') },
    { id:'LF-1005', name:'Student ID Card', desc:'Belongs to Engineering dept, photo visible.', category:'ID Cards', location:'Sports Complex', date:'2026-07-16', status:'Lost', img:PLACEHOLDER('ID+Card') },
    { id:'LF-1006', name:'Casio Wristwatch', desc:'Silver strap, small scratch on glass.', category:'Watches', location:'Parking Lot B', date:'2026-07-11', status:'Returned', img:PLACEHOLDER('Watch') },
    { id:'LF-1007', name:'Grey Backpack', desc:'Nike backpack with laptop compartment.', category:'Bags', location:'Auditorium', date:'2026-07-09', status:'Lost', img:PLACEHOLDER('Backpack') },
    { id:'LF-1008', name:'Wireless Earbuds', desc:'White case, slightly scratched.', category:'Electronics', location:'Gymnasium', date:'2026-07-13', status:'Pending', img:PLACEHOLDER('Earbuds') },
  ];

  const foundItems = [
    { id:'FD-2001', name:'Blue Umbrella', finder:'Aditi Sharma', location:'Main Gate', date:'2026-07-15', category:'Others', status:'Found', img:PLACEHOLDER('Umbrella') },
    { id:'FD-2002', name:'Silver Bracelet', finder:'Rahul Verma', location:'Cafeteria', date:'2026-07-14', category:'Others', status:'Found', img:PLACEHOLDER('Bracelet') },
    { id:'FD-2003', name:'Samsung Galaxy Buds', finder:'Meera Nair', location:'Library, 1st Floor', date:'2026-07-16', category:'Electronics', status:'Found', img:PLACEHOLDER('Earbuds') },
    { id:'FD-2004', name:'Brown Leather Bag', finder:'Karan Singh', location:'Bus Stop', date:'2026-07-12', category:'Bags', status:'Claimed', img:PLACEHOLDER('Bag') },
    { id:'FD-2005', name:'Physics Notebook', finder:'Sara Khan', location:'Room 108', date:'2026-07-10', category:'Books', status:'Found', img:PLACEHOLDER('Notebook') },
    { id:'FD-2006', name:'House Keys with Fob', finder:'Vikram Rao', location:'Parking Lot A', date:'2026-07-17', category:'Keys', status:'Found', img:PLACEHOLDER('Keys') },
  ];

  const activityLog = [
    { item:'iPhone 13 Pro', by:'Ananya Gupta', type:'Lost', date:'2026-07-15', status:'Pending' },
    { item:'Blue Umbrella', by:'Aditi Sharma', type:'Found', date:'2026-07-15', status:'Approved' },
    { item:'Casio Wristwatch', by:'Rohit Mehta', type:'Claim', date:'2026-07-14', status:'Approved' },
    { item:'Grey Backpack', by:'Priya Das', type:'Lost', date:'2026-07-13', status:'Pending' },
    { item:'Data Structures Textbook', by:'Suresh Iyer', type:'Claim', date:'2026-07-11', status:'Rejected' },
    { item:'Brown Leather Bag', by:'Karan Singh', type:'Found', date:'2026-07-12', status:'Approved' },
  ];

  /* ---------- Badge helper ---------- */
  const badgeClass = (status) => {
    switch (status) {
      case 'Lost': return 'badge-lost';
      case 'Found': return 'badge-found';
      case 'Returned': case 'Claimed': return 'badge-returned';
      case 'Pending': return 'badge-pending';
      default: return 'badge-lost';
    }
  };

  const pillClass = (status) => {
    switch (status) {
      case 'Approved': return 'pill-approved';
      case 'Rejected': return 'pill-rejected';
      default: return 'pill-pending';
    }
  };

  /* ---------- Render Lost Items ---------- */
  const lostGrid = document.getElementById('lostItemsGrid');
  const foundGrid = document.getElementById('foundItemsGrid');
  const PAGE_SIZE = 4;

  function renderLostPage(page = 1) {
    const start = (page - 1) * PAGE_SIZE;
    const pageItems = lostItems.slice(start, start + PAGE_SIZE);
    lostGrid.innerHTML = '';
    if (!pageItems.length) {
      lostGrid.innerHTML = emptyStateHTML('No lost items match your search', 'Try adjusting your filters or check back later.');
      return;
    }
    pageItems.forEach((item, i) => {
      lostGrid.insertAdjacentHTML('beforeend', `
      <div class="col-md-6 col-lg-3 fade-up delay-${i % 4}">
        <div class="item-card" data-id="${item.id}" data-type="lost">
          <div class="item-img-wrap">
            <img src="${item.img}" alt="${item.name}" loading="lazy">
            <span class="status-badge ${badgeClass(item.status)}">${item.status}</span>
          </div>
          <div class="item-body">
            <span class="item-cat-tag">${item.category}</span>
            <h5>${item.name}</h5>
            <p>${item.desc}</p>
            <div class="item-meta">
              <span><i class="fa-solid fa-location-dot"></i>${item.location}</span>
              <span><i class="fa-regular fa-calendar"></i>${formatDate(item.date)}</span>
            </div>
            <button class="btn btn-outline-grad btn-sm w-100 view-details-btn">View Details</button>
          </div>
        </div>
      </div>`);
    });
    observeFadeUps();
    buildPagination('lostPagination', lostItems.length, page, renderLostPage);
  }

  function renderFoundPage(page = 1) {
    const start = (page - 1) * PAGE_SIZE;
    const pageItems = foundItems.slice(start, start + PAGE_SIZE);
    foundGrid.innerHTML = '';
    if (!pageItems.length) {
      foundGrid.innerHTML = emptyStateHTML('No found items yet', 'Reported found items will appear here.');
      return;
    }
    pageItems.forEach((item, i) => {
      foundGrid.insertAdjacentHTML('beforeend', `
      <div class="col-md-6 col-lg-3 fade-up delay-${i % 4}">
        <div class="item-card" data-id="${item.id}" data-type="found">
          <div class="item-img-wrap">
            <img src="${item.img}" alt="${item.name}" loading="lazy">
            <span class="status-badge ${badgeClass(item.status)}">${item.status}</span>
          </div>
          <div class="item-body">
            <span class="item-cat-tag">${item.category}</span>
            <h5>${item.name}</h5>
            <div class="item-meta">
              <span><i class="fa-solid fa-user"></i>Found by ${item.finder}</span>
              <span><i class="fa-solid fa-location-dot"></i>${item.location}</span>
              <span><i class="fa-regular fa-calendar"></i>${formatDate(item.date)}</span>
            </div>
            <button class="btn btn-grad btn-sm w-100 claim-btn">Claim Item</button>
          </div>
        </div>
      </div>`);
    });
    observeFadeUps();
    buildPagination('foundPagination', foundItems.length, page, renderFoundPage);
  }

  function emptyStateHTML(title, sub) {
    return `<div class="empty-state">
      <i class="fa-solid fa-box-open"></i>
      <h5>${title}</h5>
      <p>${sub}</p>
    </div>`;
  }

  function formatDate(iso) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function buildPagination(elId, total, current, renderFn) {
    const el = document.getElementById(elId);
    const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    el.innerHTML = '';
    for (let p = 1; p <= pages; p++) {
      el.insertAdjacentHTML('beforeend', `
        <li class="page-item ${p === current ? 'active' : ''}">
          <a class="page-link" href="#" data-page="${p}">${p}</a>
        </li>`);
    }
    el.querySelectorAll('.page-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        renderFn(parseInt(link.dataset.page, 10));
        el.closest('section').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  renderLostPage(1);
  renderFoundPage(1);

  /* ---------- Item Details Modal ---------- */
  const modalEl = document.getElementById('itemDetailsModal');
  const bsModal = new bootstrap.Modal(modalEl);

  document.addEventListener('click', (e) => {
    const viewBtn = e.target.closest('.view-details-btn');
    const claimBtn = e.target.closest('.claim-btn');
    const trigger = viewBtn || claimBtn;
    if (!trigger) return;

    const card = trigger.closest('.item-card');
    const type = card.dataset.type;
    const id = card.dataset.id;
    const data = type === 'lost'
      ? lostItems.find(i => i.id === id)
      : foundItems.find(i => i.id === id);
    if (!data) return;

    document.getElementById('modalItemName').textContent = data.name;
    const bodyHTML = type === 'lost'
      ? `<img src="${data.img}" class="w-100 rounded-3 mb-3" alt="${data.name}">
         <p><strong>Description:</strong> ${data.desc}</p>
         <p><strong>Category:</strong> ${data.category}</p>
         <p><strong>Location Lost:</strong> ${data.location}</p>
         <p><strong>Date:</strong> ${formatDate(data.date)}</p>
         <p><strong>Status:</strong> <span class="status-badge ${badgeClass(data.status)}" style="position:static;display:inline-block;">${data.status}</span></p>`
      : `<img src="${data.img}" class="w-100 rounded-3 mb-3" alt="${data.name}">
         <p><strong>Found By:</strong> ${data.finder}</p>
         <p><strong>Category:</strong> ${data.category}</p>
         <p><strong>Location Found:</strong> ${data.location}</p>
         <p><strong>Date:</strong> ${formatDate(data.date)}</p>
         <p><strong>Status:</strong> <span class="status-badge ${badgeClass(data.status)}" style="position:static;display:inline-block;">${data.status}</span></p>`;
    document.getElementById('modalItemBody').innerHTML = bodyHTML;
    bsModal.show();
  });

  document.getElementById('modalClaimBtn').addEventListener('click', () => {
    bsModal.hide();
    document.getElementById('claim').scrollIntoView({ behavior: 'smooth' });
    showToast('info', 'Claim Process Started', 'Please complete the verification steps below.');
  });

  /* ---------- Admin Activity Table ---------- */
  const activityBody = document.getElementById('adminActivityBody');
  function renderActivity(rows) {
    activityBody.innerHTML = rows.map(r => `
      <tr>
        <td><strong>${r.item}</strong></td>
        <td>${r.by}</td>
        <td>${r.type}</td>
        <td>${formatDate(r.date)}</td>
        <td><span class="pill-status ${pillClass(r.status)}">${r.status}</span></td>
        <td class="text-end"><button class="btn btn-sm btn-outline-grad">Review</button></td>
      </tr>`).join('');
  }
  renderActivity(activityLog);

  /* ---------- Search / Filter (front-end demo) ---------- */
  document.getElementById('searchForm').addEventListener('submit', (e) => {
    e.preventDefault();
    showToast('success', 'Search Applied', 'Results have been filtered based on your criteria.');
    document.getElementById('lost-items').scrollIntoView({ behavior: 'smooth' });
  });

  /* ---------- Animated Counters ---------- */
  const counters = document.querySelectorAll('.counter');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        counterObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  counters.forEach(c => counterObserver.observe(c));

  function animateCounter(el) {
    const target = parseInt(el.dataset.target, 10);
    let current = 0;
    const duration = 1400;
    const stepTime = 16;
    const steps = duration / stepTime;
    const increment = target / steps;
    const tick = () => {
      current += increment;
      if (current >= target) {
        el.textContent = target;
      } else {
        el.textContent = Math.floor(current);
        requestAnimationFrame(() => setTimeout(tick, stepTime));
      }
    };
    tick();
  }

  /* ---------- Fade-up scroll animations ---------- */
  function observeFadeUps() {
    const fadeEls = document.querySelectorAll('.fade-up:not(.in-view)');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    fadeEls.forEach(el => io.observe(el));
  }
  observeFadeUps();

  /* ---------- Sticky Navbar shadow ---------- */
  const navbar = document.getElementById('mainNavbar');
  const scrollBar = document.getElementById('scrollProgressBar');
  const scrollTopBtn = document.getElementById('scrollTopBtn');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    navbar.classList.toggle('scrolled', scrollY > 30);
    scrollTopBtn.classList.toggle('show', scrollY > 400);

    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (scrollY / docHeight) * 100 : 0;
    scrollBar.style.width = progress + '%';
  });

  scrollTopBtn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  /* ---------- Dark / Light Mode Toggle ---------- */
  const themeToggle = document.getElementById('themeToggle');
  const themeIcon = themeToggle.querySelector('i');
  const savedTheme = localStorage_safe_get('theme') || 'light';
  applyTheme(savedTheme);

  themeToggle.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    applyTheme(next);
    localStorage_safe_set('theme', next);
  });

  function applyTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      themeIcon.classList.remove('fa-moon');
      themeIcon.classList.add('fa-sun');
    } else {
      document.documentElement.removeAttribute('data-theme');
      themeIcon.classList.remove('fa-sun');
      themeIcon.classList.add('fa-moon');
    }
  }

  // Safe localStorage wrappers (artifact/sandboxed environments may block storage)
  function localStorage_safe_get(key) {
    try { return localStorage.getItem(key); } catch (e) { return null; }
  }
  function localStorage_safe_set(key, val) {
    try { localStorage.setItem(key, val); } catch (e) { /* no-op */ }
  }

  /* ---------- Image Upload Preview (Lost / Found forms) ---------- */
  document.querySelectorAll('.upload-box').forEach(box => {
    const input = box.querySelector('.upload-input');
    if (!input) return;
    const previewId = box.dataset.target;
    const previewEl = previewId ? document.getElementById(previewId) : null;

    box.addEventListener('click', () => input.click());

    ['dragover', 'dragenter'].forEach(evt =>
      box.addEventListener(evt, (e) => { e.preventDefault(); box.classList.add('dragover'); })
    );
    ['dragleave', 'drop'].forEach(evt =>
      box.addEventListener(evt, (e) => { e.preventDefault(); box.classList.remove('dragover'); })
    );
    box.addEventListener('drop', (e) => {
      if (e.dataTransfer.files.length) {
        input.files = e.dataTransfer.files;
        handleFiles(e.dataTransfer.files, previewEl);
      }
    });
    input.addEventListener('change', () => handleFiles(input.files, previewEl));
  });

  function handleFiles(files, previewEl) {
    if (!previewEl || !files.length) return;
    previewEl.innerHTML = '';
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.createElement('img');
        img.src = e.target.result;
        previewEl.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  }

  /* ---------- Live Form Validation ---------- */
  document.querySelectorAll('.needs-validation').forEach(form => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        showToast('error', 'Incomplete Form', 'Please fill in all required fields correctly.');
        return;
      }
      form.classList.add('was-validated');
      const isLostForm = form.id === 'lostForm';
      showToast('success',
        isLostForm ? 'Lost Item Reported' : 'Found Item Reported',
        isLostForm ? 'We will notify you if a match is found.' : 'Thank you for helping reunite this item!');
      form.reset();
      form.classList.remove('was-validated');
      const previewTarget = form.querySelector('.image-preview');
      if (previewTarget) previewTarget.innerHTML = '';
    });

    // Real-time field validation feedback
    form.querySelectorAll('input, select, textarea').forEach(field => {
      field.addEventListener('input', () => {
        if (field.checkValidity()) {
          field.classList.remove('is-invalid');
          field.classList.add('is-valid');
        } else {
          field.classList.remove('is-valid');
          field.classList.add('is-invalid');
        }
      });
    });
  });

  /* ---------- OTP Inputs auto-advance ---------- */
  document.querySelectorAll('.otp-box').forEach((box, idx, all) => {
    box.addEventListener('input', () => {
      box.value = box.value.replace(/[^0-9]/g, '');
      if (box.value && all[idx + 1]) all[idx + 1].focus();
    });
    box.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !box.value && all[idx - 1]) all[idx - 1].focus();
    });
  });
  document.querySelectorAll('.claim-card .btn').forEach(btn => {
    btn.addEventListener('click', () => {
      showToast('success', 'Verification Submitted', 'Our team will review this step shortly.');
    });
  });

  /* ---------- Toast Notifications ---------- */
  function showToast(type, title, message) {
    const iconMap = {
      success: 'fa-circle-check text-success',
      error: 'fa-circle-xmark text-danger',
      info: 'fa-circle-info text-primary',
      warning: 'fa-triangle-exclamation text-warning'
    };
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = 'custom-toast';
    toast.innerHTML = `
      <i class="fa-solid ${iconMap[type] || iconMap.info}"></i>
      <div>
        <strong>${title}</strong>
        <p>${message}</p>
      </div>`;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(50px)';
      toast.style.transition = 'all .4s ease';
      setTimeout(() => toast.remove(), 400);
    }, 4200);
  }

  // Welcome toast
  setTimeout(() => showToast('info', 'Welcome to FindIt Campus', 'Browse recent items or report one in seconds.'), 1400);

  /* ---------- Smooth scroll for in-page nav links ---------- */
  document.querySelectorAll('a.nav-link, a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href && href.length > 1 && href.startsWith('#')) {
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          const collapse = document.getElementById('navMain');
          if (collapse.classList.contains('show')) {
            bootstrap.Collapse.getOrCreateInstance(collapse).hide();
          }
        }
      }
    });
  });

  /* ---------- Category card click -> filter demo ---------- */
  document.querySelectorAll('.category-card').forEach(card => {
    card.addEventListener('click', () => {
      const cat = card.querySelector('span').textContent;
      showToast('info', `Browsing: ${cat}`, 'Showing lost & found items in this category.');
      document.getElementById('lost-items').scrollIntoView({ behavior: 'smooth' });
    });
  });

});

</script>
</body>
</html>
